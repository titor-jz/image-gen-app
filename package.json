{
  "name": "image-gen-app",
  "version": "1.0.0",
  "description": "AI Image Generation Desktop App",
  "author": "AI Image Gen",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "next build && cross-env NEXT_PORT=3001 electron .",
    "electron:build": "next build && electron-builder --win --x64",
    "dist": "npm run electron:build"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "idb": "^8.0.3",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "openai": "^6.43.0",
    "proxy-from-env": "^2.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.ai-image-gen.app",
    "productName": "AI Image Gen",
    "asar": false,
    "directories": {
      "output": "dist2",
      "buildResources": "build"
    },
    "files": [
      ".next/standalone/**",
      ".next/static/**",
      "electron/**",
      "public/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/static",
        "to": ".next/static"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Image Gen"
    }
  }
}
